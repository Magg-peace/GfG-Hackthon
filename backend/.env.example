# ── PostgreSQL (required for full feature set) ────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bi_dashboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Giri@#2004

# ── Ollama (local LLMs – PRIMARY, free, no API key needed) ───────────────────
# Download from https://ollama.com
# Then run: ollama pull deepseek-coder
#           ollama pull qwen2.5-coder
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120

# Override specific model choices (leave blank for auto-selection):
# OLLAMA_SQL_MODEL=deepseek-v3
# OLLAMA_VIZ_MODEL=qwen3:14b

# ── Google Gemini (cloud fallback – used when Ollama is unavailable) ─────────
# Get a free API key at https://aistudio.google.com
# If both Ollama and Gemini are configured, Ollama is used for local privacy.
GEMINI_API_KEY=
